# === X / Twitter API Credentials ===
# Create an app at https://developer.twitter.com/en/portal/dashboard
X_API_KEY=your_api_key
X_API_SECRET=your_api_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_SECRET=your_access_secret

# === GitHub API Token (optional but recommended) ===
# Unauthenticated: 60 req/hr | Authenticated: 5,000 req/hr
# Create at https://github.com/settings/tokens (no special scopes needed)
GITHUB_TOKEN=your_github_token

# === Bot Settings ===
# Cron schedule for daily posting (default: 9:00 AM UTC)
CRON_SCHEDULE=0 9 * * *

# How many projects to include per post batch (default: 5)
PROJECTS_PER_POST=5

# Which GitHub Trending time range: daily, weekly, monthly
TRENDING_PERIOD=daily

# Languages to filter (comma-separated, or "all" for everything)
# Examples: python,javascript,rust,go
TRENDING_LANGUAGES=all

# Post as a thread (true) or individual tweets (false)
POST_AS_THREAD=true
