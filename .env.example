# X / Twitter API credentials (API v2 — Bearer Token is required)
X_BEARER_TOKEN=your_bearer_token_here

# Optional: X API v1.1 credentials (needed for some endpoints)
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# GitHub personal access token (increases rate limits from 60 → 5000 req/hr)
GITHUB_TOKEN=your_github_token_here

# Optional: How many tweets to scan per query (default 100, max 500)
MAX_TWEETS=100

# Optional: Minimum engagement threshold to consider a tweet "viral"
MIN_LIKES=50
MIN_RETWEETS=20
