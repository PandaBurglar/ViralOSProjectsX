# === X / Twitter API Credentials (for search) ===
# Create an app at https://developer.twitter.com/en/portal/dashboard
X_BEARER_TOKEN=your_bearer_token
X_API_KEY=your_api_key
X_API_SECRET=your_api_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_SECRET=your_access_secret

# === GitHub API Token (recommended — 5k req/hr vs 60) ===
# Create at https://github.com/settings/tokens (classic, no scopes needed)
GITHUB_TOKEN=your_github_token

# === Search Settings ===
# Pipe-separated X search queries (each run independently, results merged)
# Default: "open source" url:"github.com" | "OSS" url:"github.com" | "open source project" url:"github.com"
# SEARCH_QUERIES="open source" url:"github.com" -is:retweet|"OSS" url:"github.com" -is:retweet

# Max tweets to fetch per query (10-100)
MAX_RESULTS=50

# Min total retweets+likes for a repo to be included
MIN_ENGAGEMENT=10

# Max projects to include in the daily report
PROJECTS_PER_POST=20

# === Output ===
# Path to save daily markdown reports (auto-creates directories)
# LEADSCRM_WORKSPACE_PATH=/path/to/LeadsCrm/workspace/reports/viral-oss

# === Scheduling ===
# Cron expression for daily report (default: 9:00 AM UTC)
CRON_SCHEDULE=0 9 * * *
